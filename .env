# Watchable marketing site local defaults

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Watchable
NEXT_PUBLIC_PRODUCT_APP_URL=https://app.watchable-ai.com

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Next.js
NEXT_TELEMETRY_DISABLED=1

# Logging
NEXT_PUBLIC_LOGGING_LEVEL=debug

######## [BEGIN] SENSITIVE DATA ########
######## Create `.env.local` for machine-specific secrets.
# Arcjet
# ARCJET_KEY=
######## [END] SENSITIVE DATA ########
