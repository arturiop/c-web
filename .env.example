# Watchable marketing site example environment

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Watchable
NEXT_PUBLIC_PRODUCT_APP_URL=https://app.watchable-ai.com

# Optional analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DISABLED=

# Optional logging
NEXT_PUBLIC_LOGGING_LEVEL=info

# Disable Next.js telemetry locally when preferred
NEXT_TELEMETRY_DISABLED=1
