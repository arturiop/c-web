{
  "name": "marketing-site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "clean": "rimraf .next out coverage storybook-static test-results vitest-test-results",
    "typecheck": "tsc --noEmit --pretty",
    "lint": "ultracite check --type-aware --type-check",
    "lint:fix": "ultracite fix --type-aware --type-check",
    "check:types": "tsc --noEmit --pretty",
    "check:deps": "knip",
    "check:i18n": "i18n-check -l src/locales -s en -u src -f next-intl",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "storybook:test": "vitest run --config .storybook/vitest.config.ts",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@arcjet/next": "^1.4.0",
    "@sentry/nextjs": "^10.52.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "next": "^16.2.6",
    "next-intl": "^4.11.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@chromatic-com/playwright": "^0.14.2",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/prompt-cli": "^20.5.3",
    "@lingual/i18n-check": "^0.9.5",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/nextjs-vite": "^10.3.6",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "knip": "^6.12.2",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.23.0",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "ultracite": "^7.7.0",
    "vitest": "^4.1.5",
    "vitest-browser-react": "^2.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "postcss": {
    "plugins": {
      "@tailwindcss/postcss": {}
    }
  }
}
